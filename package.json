  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives",
    "preview": "vite preview",
    "docker:build": "docker build -t door43-preview-app .",
    "docker:run": "docker run -p 3000:3000 -e PORT=3000 --env-file .env door43-preview-app",
